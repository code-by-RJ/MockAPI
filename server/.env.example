# Environment Variables Template

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mockapi

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# CORS Configuration — the frontend origin(s) allowed to call this API with credentials.
# Comma-separate multiple domains if needed, e.g.:
# CLIENT_URL=https://mockapi.spacego.online,https://www.spacego.online
CLIENT_URL=http://localhost:5173

# Faker Configuration
FAKER_SEED=12345

# Resend API Key
RESEND_API_KEY = re_xxxxxxxxxxxxxxxxxxxxxxxx
